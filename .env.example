# =========================================================
# NEXSCHOOL AI — ENV VARIABLES TEMPLATE
# =========================================================
# 📋  Copy to .env.local and fill in real values.
#     This file is SAFE to commit. Never commit .env.local.
# =========================================================


# ─────────────────────────────────────────────────
# 1. APPLICATION
# ─────────────────────────────────────────────────
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://yourdomain.com"


# ─────────────────────────────────────────────────
# 2. SUPABASE
# 📍 app.supabase.com → Project Settings → API
# ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# PgBouncer — port 6543 mandatory for production serverless
# DATABASE_URL=""
# DIRECT_URL=""


# ─────────────────────────────────────────────────
# 3. SECURITY
# 📍 Generate: openssl rand -hex 32
# ─────────────────────────────────────────────────
JWT_SECRET=""
CRON_SECRET=""


# ─────────────────────────────────────────────────
# 4. RAZORPAY
# 📍 dashboard.razorpay.com → Settings → API Keys + Webhooks
# ─────────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""


# ─────────────────────────────────────────────────
# 5. UPSTASH REDIS
# 📍 console.upstash.com → REST API tab
# ─────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""


# ─────────────────────────────────────────────────
# 6. NOTIFICATIONS (Twilio SMS)
# 📍 console.twilio.com → Account Info
# ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""


# ─────────────────────────────────────────────────
# 7. MONITORING
# 📍 sentry.io → New Project → Next.js → DSN
# ─────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Slack or Discord Incoming Webhook for backend alerts
ALERT_WEBHOOK_URL=""


# ─────────────────────────────────────────────────
# 8. FEATURE FLAGS (toggle without redeploying)
# ─────────────────────────────────────────────────
FEATURE_AI_MODULE="true"
FEATURE_ADVANCED_ANALYTICS="true"
FEATURE_TRANSPORT_GPS="true"
FEATURE_HOSTEL="true"


# ─────────────────────────────────────────────────
# 9. RATE LIMITING
# ─────────────────────────────────────────────────
RATE_LIMIT_REQUESTS="60"
RATE_LIMIT_WINDOW="60"
RATE_LIMIT_WEBHOOK_REQUESTS="10"


# ─────────────────────────────────────────────────
# 10. BACKUP
# 📍 AWS S3 or Cloudflare R2 (recommended — no egress fees)
# ─────────────────────────────────────────────────
BACKUP_S3_BUCKET="nexschool-backups"
BACKUP_REGION="ap-south-1"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
